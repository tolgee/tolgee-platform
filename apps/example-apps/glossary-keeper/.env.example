# Anthropic API key — used for term detection (Haiku) and suggestion drafting (Sonnet).
ANTHROPIC_API_KEY=

# Optional model overrides.
# ANTHROPIC_MODEL_DETECT=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_SUGGEST=claude-sonnet-4-6

# Tolgee instance to register the app against (defaults to https://app.tolgee.io).
# TOLGEE_URL=

# Populated by `npm run register` — you normally don't set these by hand.
# TOLGEE_WEBHOOK_SECRET=
