{
  "name": "@tginternal/client",
  "version": "0.0.0-prerelease.45c1441e6",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tolgee/tolgee-platform.git",
    "directory": "client"
  },
  "homepage": "https://github.com/tolgee/tolgee-platform/tree/main/client",
  "bugs": "https://github.com/tolgee/tolgee-platform/issues",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "lib"
  ],
  "main": "./dist/client.umd.cjs",
  "module": "./dist/client.js",
  "types": "./lib/main.d.ts",
  "exports": {
    ".": {
      "types": "./lib/main.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.umd.cjs",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "update-version": "node scripts/updateVersion.js",
    "schema": "openapi-typescript http://localhost:${TOLGEE_API_PORT:-8080}/v3/api-docs/All%20Internal%20-%20for%20Tolgee%20Web%20application --output src/schema.generated.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "base32-decode": "^1.0.0",
    "openapi-fetch": "^0.14.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.9.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
